    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
